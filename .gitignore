# Terraform local working directories
.terraform/
**/.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform variable files can contain secrets or environment-specific values.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Terraform plan output
*.tfplan
tfplan

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local CLI/config files
.terraformrc
terraform.rc

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
